<Window
    x:Class="Quantum.Editor.Avalonia.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dock="using:Dock.Avalonia.Controls"
    Title="Quantum CoasterWorks Editor"
    Width="1480"
    Height="920"
    MinWidth="1120"
    MinHeight="720"
    Background="#0D1218"
    KeyDown="OnWindowKeyDown">
    <Window.Styles>
        <Style Selector="Border.panel">
            <Setter Property="Background" Value="#151C24" />
            <Setter Property="BorderBrush" Value="#2B3948" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style Selector="TextBlock.panelTitle">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="#AFC4D8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
        <Style Selector="Button.toolbar">
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="MinWidth" Value="58" />
        </Style>
        <Style Selector="TextBox.inspectorField">
            <Setter Property="MinHeight" Value="28" />
        </Style>
        <Style Selector="Button.graphNode">
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="8,0" />
            <Setter Property="Background" Value="#18232E" />
            <Setter Property="BorderBrush" Value="#34495C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="5" />
        </Style>
    </Window.Styles>

    <Grid x:Name="WorkbenchGrid" RowDefinitions="Auto,48,*,28">
        <Border
            x:Name="MenuBarRegion"
            Grid.Row="0"
            Background="#111820"
            BorderBrush="#2B3948"
            BorderThickness="0,0,0,1">
            <Menu>
                <MenuItem x:Name="FileMenu" Header="_File">
                    <MenuItem Header="_New Track    Ctrl+N" Click="OnNewDocumentClick" />
                    <MenuItem Header="_Open…    Ctrl+O" Click="OnOpenDocumentClick" />
                    <Separator />
                    <MenuItem Header="_Save    Ctrl+S" Click="OnSaveDocumentClick" />
                    <MenuItem Header="Save _As…    Ctrl+Shift+S" Click="OnSaveDocumentAsClick" />
                    <Separator />
                    <MenuItem Header="E_xit" Click="OnExitClick" />
                </MenuItem>
                <MenuItem x:Name="EditMenu" Header="_Edit">
                    <MenuItem x:Name="UndoMenuItem" Header="_Undo    Ctrl+Z" Click="OnUndoClick" />
                    <MenuItem x:Name="RedoMenuItem" Header="_Redo    Ctrl+Y" Click="OnRedoClick" />
                </MenuItem>
                <MenuItem x:Name="ViewMenu" Header="_View">
                    <MenuItem Header="_Fit Track    F" Click="OnFitViewportClick" />
                    <MenuItem Header="Toggle Transported _Frames" Click="OnMenuShowFramesClick" />
                    <MenuItem Header="Math _Plots" Click="OnShowEngineeringPlotsClick" />
                    <Separator />
                    <MenuItem x:Name="PanesMenu" Header="_Panes" />
                    <Separator />
                    <MenuItem Header="_Reset Layout" Click="OnResetLayoutClick" />
                </MenuItem>
            </Menu>
        </Border>

        <Border
            x:Name="ToolbarRegion"
            Grid.Row="1"
            Background="#121A22"
            BorderBrush="#2B3948"
            BorderThickness="0,0,0,1"
            Padding="10,7">
            <Grid ColumnDefinitions="Auto,Auto,Auto,16,Auto,Auto,16,Auto,Auto,*,Auto,12,Auto">
                <Button x:Name="NewButton" Classes="toolbar" Content="New" Click="OnNewDocumentClick" />
                <Button x:Name="OpenButton" Grid.Column="1" Classes="toolbar" Content="Open" Click="OnOpenDocumentClick" />
                <Button x:Name="SaveButton" Grid.Column="2" Classes="toolbar" Content="Save" Click="OnSaveDocumentClick" />
                <Button x:Name="UndoButton" Grid.Column="4" Classes="toolbar" Content="Undo" Click="OnUndoClick" />
                <Button x:Name="RedoButton" Grid.Column="5" Classes="toolbar" Content="Redo" Click="OnRedoClick" />
                <Button x:Name="FitButton" Grid.Column="7" Classes="toolbar" Content="Fit" Click="OnFitViewportClick" />
                <CheckBox
                    x:Name="ShowFramesCheckBox"
                    Grid.Column="8"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Content="Frames"
                    IsChecked="True"
                    IsCheckedChanged="OnShowFramesChanged" />
                <StackPanel
                    Grid.Column="10"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="8">
                    <TextBlock VerticalAlignment="Center" Foreground="#9EB3C7" Text="Workspace" />
                    <ComboBox
                        x:Name="WorkspaceSelectorComboBox"
                        Width="190"
                        SelectionChanged="OnWorkspaceSelectorChanged" />
                </StackPanel>
                <ComboBox
                    x:Name="ProjectionComboBox"
                    Grid.Column="12"
                    Width="145"
                    SelectedIndex="0"
                    SelectionChanged="OnProjectionChanged">
                    <ComboBoxItem Content="Isometric" />
                    <ComboBoxItem Content="Top · X/Z" />
                    <ComboBoxItem Content="Side · X/Y" />
                </ComboBox>
            </Grid>
        </Border>

        <dock:DockControl
            x:Name="DockHost"
            Grid.Row="2"
            InitializeFactory="False"
            InitializeLayout="False" />

        <Border
            x:Name="StatusBarRegion"
            Grid.Row="3"
            Background="#0B1016"
            BorderBrush="#2B3948"
            BorderThickness="0,1,0,0"
            Padding="10,4">
            <Grid ColumnDefinitions="*,Auto,20,Auto">
                <TextBlock x:Name="StatusMessageText" VerticalAlignment="Center" Foreground="#9EB3C7" />
                <TextBlock x:Name="SelectionText" Grid.Column="1" VerticalAlignment="Center" Foreground="#7F94A8" />
                <TextBlock x:Name="DocumentStateText" Grid.Column="3" VerticalAlignment="Center" Foreground="#C7D7E5" />
            </Grid>
        </Border>
    </Grid>
</Window>
